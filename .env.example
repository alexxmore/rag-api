APP_NAME=Production RAG API
ENVIRONMENT=local
API_KEYS_FILE=config/api_keys.yaml

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=Production RAG API

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_BACKEND=faiss
VECTOR_INDEX_PATH=data/vector_index
SOURCE_PATH=data/source.md
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_CHUNKS_COLLECTION=rag_chunks
QDRANT_CACHE_COLLECTION=rag_semantic_cache

REDIS_URL=redis://localhost:6379/0
SQLITE_PATH=data/usage.sqlite3

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

MAX_LLM_CONCURRENCY=20
CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_TTL_SECONDS=3600
